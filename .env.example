# KOPIS API
KOPIS_API_KEY=your-kopis-api-key

# OAuth2 - 카카오
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# OAuth2 - 네이버
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# OAuth2 - 구글
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT
JWT_SECRET=your-super-secret-jwt-key-must-be-at-least-256-bits-long

# Frontend URL (배포 시 변경)
FRONTEND_URL=http://localhost:3000

# DigitalOcean Spaces (이미지 업로드)
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_REGION=sgp1
DO_SPACES_ACCESS_KEY=your-spaces-access-key
DO_SPACES_SECRET_KEY=your-spaces-secret-key
DO_SPACES_BUCKET=curtaincall
DO_SPACES_CDN_URL=https://curtaincall.sgp1.cdn.digitaloceanspaces.com
